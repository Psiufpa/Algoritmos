algoritmo "lista 3 - problema 11"

var
  
  soma, multiplicacao, num1, num2, i: inteiro
  

inicio
soma <- 0
multiplicacao <- 1

leia(num1)
leia(num2)

para i de num1 ate num2 faca

  se i mod 2 = 0 entao

    soma <- soma + i
  
  senao

    multiplicacao <- multiplicacao * i

  fimse

fimpara

escreval("Soma: ", soma)
escreval("Multiplicação: ", multiplicacao)



fimalgoritmo