algoritmo "lista 03 - problema 06"

var
  menor , maior : inteiro 
  num: inteiro
  

inicio

   
   leia(num)
   menor <- num
   maior <- num

   enquanto num <> -1 faca
      
      leia(num)

      se num > maior entao
        
        maior <- num
      
      fimse
      se num < menor e num <> -1 entao
        
        menor <- num
      
      fimse
      
   
   fimenquanto

     
  escreval("maior = ", maior)
  escreval("menor = ", menor)
  
fimalgoritmo
